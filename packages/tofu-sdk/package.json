{
  "name": "@tofu-sdk/core",
  "version": "0.0.0",
  "description": "Write Terraform/OpenTofu providers in TypeScript, backed by a Rust tfplugin6 core.",
  "license": "MIT OR Apache-2.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tsdown": {
      "types": "./dist/tsdown.d.ts",
      "default": "./dist/tsdown.js"
    }
  },
  "files": [
    "dist",
    "binding"
  ],
  "napi": {
    "binaryName": "tofu-sdk",
    "targets": [
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "pnpm run build:native && pnpm run build:ts",
    "build:native": "napi build --platform --release --manifest-path native/Cargo.toml --output-dir binding --js index.js --dts index.d.ts",
    "build:ts": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test test/*.test.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "@types/node": "^22",
    "cloudflare": "^6.4.0",
    "tsdown": "^0.22.3",
    "typescript": "^5"
  },
  "peerDependencies": {
    "tsdown": "^0.22"
  },
  "peerDependenciesMeta": {
    "tsdown": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
